### 学途智慧教育平台 - 快速测试脚本
### 使用IDEA HTTP Client或VSCode REST Client插件运行
### 测试日期: 2024-10-03

####################################
### 1. 用户服务测试 (端口: 8088)
####################################

### 1.1 健康检查
GET http://localhost:8088/auth/health

### 1.2 用户注册
POST http://localhost:8088/auth/register
Content-Type: application/json

{
  "username": "testuser01",
  "password": "test123456",
  "email": "testuser01@example.com",
  "nickname": "测试用户01"
}

### 1.3 检查用户名是否可用
GET http://localhost:8088/auth/check-username?username=testuser01

### 1.4 用户登录
POST http://localhost:8088/auth/login
Content-Type: application/json

{
  "username": "testuser01",
  "password": "test123456"
}

> {%
    client.global.set("userToken", response.body.data.token);
    client.global.set("userId", response.body.data.userInfo.id);
%}

### 1.5 获取用户详情（使用具体的用户ID）
GET http://localhost:8088/user/1

### 1.6 禁用用户（管理员操作）
POST http://localhost:8088/user/1/disable

### 1.7 启用用户（管理员操作）
POST http://localhost:8088/user/1/enable

### 1.8 更新用户状态为禁用（管理员操作）
POST http://localhost:8088/user/1/status?status=0

### 1.9 更新用户状态为启用（管理员操作）
POST http://localhost:8088/user/1/status?status=1

### 1.10 修改用户密码
POST http://localhost:8088/user/1/change-password
Content-Type: application/json

{
  "oldPassword": "test123456",
  "newPassword": "newPassword123",
  "confirmPassword": "newPassword123"
}

### 1.11 用户管理健康检查
GET http://localhost:8088/user/health

####################################
### 2. 管理服务测试 (端口: 待确认)
####################################

### 2.1 获取权限列表
GET http://localhost:8099/permission/list

### 2.2 创建权限
POST http://localhost:8099/permission/create
Content-Type: application/json

{
  "permissionKey": "course:view",
  "permissionName": "查看课程",
  "description": "查看课程详情的权限"
}

### 2.3 获取角色列表
GET http://localhost:8099/role/list

### 2.4 创建角色
POST http://localhost:8099/role/create
Content-Type: application/json

{
  "roleName": "student",
  "roleKey": "STUDENT",
  "description": "普通学生角色"
}

### 2.5 为角色授予权限
POST http://localhost:8099/role/grant
Content-Type: application/json

{
  "roleId": 2,
  "permissionIds": [1, 2, 3, 4]
}

### 2.6 为用户分配角色
POST http://localhost:8099/role/assign
Content-Type: application/json

{
  "userId": 1,
  "roleId": 2
}

####################################
### 3. 课程服务测试 (端口: 8077)
####################################

### 3.1 创建分类
POST http://localhost:8077/category
Content-Type: application/json

{
  "name": "编程语言",
  "parentId": 0,
  "sortOrder": 1,
  "description": "各种编程语言课程"
}

### 3.2 获取分类树
GET http://localhost:8077/category/tree

### 3.3 创建课程
POST http://localhost:8077/course
Content-Type: application/json

{
  "title": "Java从入门到精通",
  "subtitle": "全面系统地学习Java编程",
  "categoryId": 1,
  "teacherId": 1,
  "coverImage": "https://example.com/java-course.jpg",
  "description": "这是一门完整的Java编程课程，适合零基础学员",
  "price": 199.00,
  "level": 0,
  "tags": "Java,编程,后端"
}

> {%
    client.global.set("courseId", response.body.data);
%}

### 3.4 获取课程列表
GET http://localhost:8077/course/list?current=1&size=10

### 3.5 获取课程详情
GET http://localhost:8077/course/{{courseId}}

### 3.6 发布课程
POST http://localhost:8077/course/{{courseId}}/publish

### 3.7 获取热门课程
GET http://localhost:8077/course/hot?limit=10

### 3.8 创建章节
POST http://localhost:8077/chapter/course/{{courseId}}
Content-Type: application/json

{
  "title": "第一章：Java基础",
  "description": "介绍Java基础知识和环境搭建",
  "sortOrder": 1
}

> {%
    client.global.set("chapterId", response.body.data);
%}

### 3.9 获取课程章节列表
GET http://localhost:8077/chapter/course/{{courseId}}

### 3.10 创建评论
POST http://localhost:8077/comment
Content-Type: application/json
X-User-Id: 1

{
  "courseId": 1,
  "content": "这门课程非常好，讲解清晰，推荐！",
  "rating": 5
}

> {%
    client.global.set("commentId", response.body.data);
%}

### 3.11 获取课程评论
GET http://localhost:8077/comment/course/{{courseId}}?current=1&size=10

### 3.12 点赞评论
POST http://localhost:8077/comment/{{commentId}}/like
X-User-Id: 1

### 3.13 获取评论统计
GET http://localhost:8077/comment/course/{{courseId}}/statistics

####################################
### 4. 订单服务测试 (端口: 8055)
####################################

### 4.1 检查是否可购买
POST http://localhost:8055/api/orders/check-purchasable
Content-Type: application/json
X-User-Id: 1

{
  "courseIds": [1]
}

### 4.2 创建订单
POST http://localhost:8055/api/orders
Content-Type: application/json
X-User-Id: 1

{
  "courseIds": [1],
  "remark": "测试订单"
}

> {%
    client.global.set("orderId", response.body.data.id);
    client.global.set("orderNo", response.body.data.orderNo);
%}

### 4.3 查询订单详情
GET http://localhost:8055/api/orders/{{orderId}}

### 4.4 根据订单号查询订单
GET http://localhost:8055/api/orders/order-no/{{orderNo}}

### 4.5 查询我的订单
GET http://localhost:8055/api/orders/my?current=1&size=10
X-User-Id: 1

### 4.6 快捷支付（创建+支付一步完成）
POST http://localhost:8055/api/payments/quick-pay
Content-Type: application/json
X-User-Id: 1

{
  "orderNo": "{{orderNo}}",
  "paymentMethod": 1,
  "amount": 199.00
}

> {%
    client.global.set("paymentNo", response.body.data.paymentNo);
%}

### 4.7 查询支付记录
GET http://localhost:8055/api/payments/{{paymentNo}}

### 4.8 查询支付状态
GET http://localhost:8055/api/payments/{{paymentNo}}/status

####################################
### 5. 学习服务测试 (端口: 8044)
####################################

### 5.1 更新学习进度
POST http://localhost:8044/learning/record/progress
Content-Type: application/json
X-User-Id: 1

{
  "courseId": 1,
  "lessonId": 1,
  "progress": 300,
  "duration": 600
}

### 5.2 获取课程学习记录
GET http://localhost:8044/learning/record/course/{{courseId}}
X-User-Id: 1

### 5.3 获取学习统计
GET http://localhost:8044/learning/record/stats
X-User-Id: 1

### 5.4 获取最近学习记录
GET http://localhost:8044/learning/record/recent?limit=10
X-User-Id: 1

### 5.5 获取课程学习进度
GET http://localhost:8044/learning/record/progress/{{courseId}}
X-User-Id: 1

### 5.6 标记课时完成
POST http://localhost:8044/learning/record/complete?courseId={{courseId}}&lessonId=1
X-User-Id: 1

### 5.7 创建笔记
POST http://localhost:8044/learning/note
Content-Type: application/json
X-User-Id: 1

{
  "courseId": 1,
  "lessonId": 1,
  "content": "这节课学习了Java基础语法，包括变量、数据类型、运算符等内容。重点掌握了面向对象的三大特性。",
  "timepoint": 120
}

> {%
    client.global.set("noteId", response.body.data);
%}

### 5.8 获取课程笔记
GET http://localhost:8044/learning/note/course/{{courseId}}
X-User-Id: 1

### 5.9 搜索笔记
GET http://localhost:8044/learning/note/search?keyword=Java&limit=20
X-User-Id: 1

### 5.10 获取最近笔记
GET http://localhost:8044/learning/note/recent?limit=10
X-User-Id: 1

### 5.11 获取笔记统计
GET http://localhost:8044/learning/note/count
X-User-Id: 1

